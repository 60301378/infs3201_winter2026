<link rel="stylesheet" href="/styles.css">

<h1>Login</h1>

{{#if msg}}
  <p>{{msg}}</p>
{{/if}}

<form method="POST" action="/login">
  <label>Username:</label>
  <input type="text" name="username">
  <br>

  <label>Password:</label>
  <input type="password" name="password">
  <br>

  <button type="submit">Login</button>
</form>
